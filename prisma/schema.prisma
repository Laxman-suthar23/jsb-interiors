generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  clientName  String
  architect   String
  type        String
  location    String
  duration    String
  description String
  coverImage  String
  featured    Boolean  @default(false)

  images      Image[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([featured])
}


model Image {
  id        String   @id @default(cuid())
  url       String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  message   String
  rating    Int?
  project   String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
